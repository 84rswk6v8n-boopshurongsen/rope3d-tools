{
  "package_version": 2,
  "name": "rope3d-tools",
  "version": "0.2.4",
  "author": "舒荣森",
  "editor": ">=3.8.0",
  "description": "Cocos Creator 3.8.x 3D 绳索编辑器扩展。支持一键创建 3D 绳索节点，并自动安装 Rope3D 运行时代码模板到项目 assets/rope3d。",
  "main": "./main.js",
  "contributions": {
    "menu": [
      {
        "path": "i18n:menu.node",
        "label": "3D 绳索",
        "message": "create-rope3d-node"
      }
    ],
    "messages": {
      "create-rope3d-node": {
        "methods": [
          "createRope3DNode"
        ]
      }
    },
    "hierarchy": {
      "menu": {
        "methods": "./hierarchy-menu.js",
        "createMenu": "getCreateMenu",
        "nodeMenu": "getNodeMenu",
        "rootMenu": "getRootMenu"
      }
    },
    "scene": {
      "script": "./scene.js",
      "methods": [
        "createRope3DNodeV2"
      ]
    }
  }
}
